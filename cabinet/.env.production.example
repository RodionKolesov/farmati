# ============================================================================
# ПРОД: cabinet (личный кабинет, React+Vite) на self-hosted Supabase в Yandex Cloud
# Скопируйте в .env.production и подставьте значения из вашего self-hosted Supabase.
# Supabase развёрнут на ВМ Yandex Compute в РФ — данные клиентов в России.
# ============================================================================

# URL вашего self-hosted Supabase (домен/IP ВМ в Yandex Cloud, через HTTPS).
# Например https://api.lk.farmati.ru  (Kong слушает порт 8000 за reverse-proxy).
VITE_SUPABASE_URL=https://api.lk.farmati.ru

# Публичный anon-ключ из .env вашего self-hosted Supabase (ANON_KEY).
VITE_SUPABASE_ANON_KEY=ЗАМЕНИТЕ_НА_ANON_KEY_ИЗ_SELFHOSTED_SUPABASE
